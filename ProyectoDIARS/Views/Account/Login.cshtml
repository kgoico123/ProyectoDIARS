@{
    ViewBag.Title = "Iniciar sesión";
    Layout = null; // O usa tu layout principal si corresponde
}

<style>
    body {
        background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-container {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.10);
        width: 420px;
        max-width: 95vw;
        margin: 60px auto;
        padding: 40px 36px 32px 36px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .login-title {
        font-size: 2.2rem;
        font-weight: bold;
        margin-bottom: 24px;
        text-align: center;
    }

    .login-role-row {
        display: flex;
        justify-content: center;
        gap: 80px;
        margin-bottom: 14px;
    }

    .login-role {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

        .login-role input[type="radio"] {
            margin-bottom: 5px;
            accent-color: #2575fc;
            transform: scale(1.3);
        }

        .login-role img {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            margin-bottom: 4px;
            object-fit: cover;
            background: #f1f1f1;
            border: 2px solid #e0e0e0;
        }

        .login-role label {
            font-weight: 600;
            font-size: 1.12rem;
            margin-top: 4px;
        }

    .form-group {
        margin-bottom: 14px;
        width: 100%;
    }

    .form-control {
        width: 100%;
        padding: 9px 12px;
        border-radius: 6px;
        border: 1px solid #c7c7c7;
        font-size: 1rem;
        margin-bottom: 2px;
    }

    .btn {
        padding: 9px 22px;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        cursor: pointer;
        transition: background .2s;
        margin-right: 10px;
    }

    .btn-primary {
        background: #2575fc;
        color: #fff;
    }

        .btn-primary:hover {
            background: #194ac6;
        }

    .btn-secondary {
        background: #e0e0e0;
        color: #333;
    }

        .btn-secondary:hover {
            background: #b1b1b1;
        }

    .login-links {
        text-align: center;
        margin-top: 12px;
        font-size: 1rem;
    }

        .login-links a {
            color: #2575fc;
            text-decoration: underline;
            margin: 0 2px;
        }

    .alert {
        margin-top: 12px;
        color: #fff;
        background: #e74c3c;
        padding: 7px 18px;
        border-radius: 6px;
        font-size: 1rem;
        text-align: center;
    }
</style>

<div class="login-container">
    <div class="login-title">Iniciar sesión</div>
    <form asp-action="Login" method="post" style="width:100%;">
        <div class="login-role-row">
            <div class="login-role">
                <input type="radio" name="userType" value="Padre" id="padreRadio" checked onchange="toggleLoginFields()" />
                <img src="~/Content/icons/parent.png" alt="Padre" onerror="this.src='https://cdn-icons-png.flaticon.com/512/194/194938.png';" />
                <label for="padreRadio">Padre</label>
            </div>
            <div class="login-role">
                <input type="radio" name="userType" value="Profesor" id="profesorRadio" onchange="toggleLoginFields()" />
                <img src="~/Content/icons/teacher.png" alt="Profesor" onerror="this.src='https://cdn-icons-png.flaticon.com/512/194/194935.png';" />
                <label for="profesorRadio">Profesor</label>
            </div>
        </div>

        <div class="form-group">
            <input type="text" name="dni" id="dni" class="form-control" placeholder="DNI" required />
        </div>
        <div class="form-group" id="passwordDiv" style="display:none;">
            <input type="password" name="password" class="form-control" placeholder="Contraseña" />
        </div>
        <div style="display:flex; justify-content:center;">
            <button type="submit" class="btn btn-primary">Iniciar sesión</button>
            <button type="button" class="btn btn-secondary" onclick="window.location.href='/'">Cancelar</button>
        </div>
        <div class="login-links">
            <a href="#">Registrar</a> / <a href="#">Recuperar contraseña</a>
        </div>
        @if (ViewBag.Error != null)
        {
            <div class="alert">@ViewBag.Error</div>
        }
    </form>
</div>

<script>
    function toggleLoginFields() {
        var userType = document.querySelector('input[name="userType"]:checked').value;
        var passwordDiv = document.getElementById('passwordDiv');
        if (userType === "Profesor") {
            passwordDiv.style.display = "block";
            document.getElementsByName("password")[0].setAttribute("required", "required");
        } else {
            passwordDiv.style.display = "none";
            document.getElementsByName("password")[0].removeAttribute("required");
        }
    }
    // Inicializa al cargar
    toggleLoginFields();
</script>