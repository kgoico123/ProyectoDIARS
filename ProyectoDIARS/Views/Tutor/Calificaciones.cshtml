@{
    ViewData["Title"] = "Calificaciones";
    var estudiante = ViewBag.Estudiante as ProyectoDIARS.Models.Estudiante;
    var calificaciones = ViewBag.Calificaciones as List<ProyectoDIARS.Models.Calificacion> ?? new List<ProyectoDIARS.Models.Calificacion>();

    // Agrupa por curso y toma el último promedioAcumulado para el gráfico
    var promediosPorCurso = ViewBag.PromediosPorCurso;

    string NotaLiteral(int puntaje)
    {
        if (puntaje >= 18) return "AD";
        if (puntaje >= 14) return "A";
        if (puntaje >= 11) return "B";
        return "C";
    }
    string PromedioLiteral(double promedio)
    {
        if (promedio >= 18) return "AD";
        if (promedio >= 14) return "A";
        if (promedio >= 11) return "B";
        return "C";
    }
    string ColorNota(string literal)
    {
        return literal switch
        {
            "AD" => "#22c55e",
            "A" => "#4ade80",
            "B" => "#fde047",
            "C" => "#f87171",
            _ => "#ccc"
        };
    }
}

<h2 class="text-xl font-bold mb-4 text-blue-700">Calificaciones de @estudiante?.user?.UserName</h2>

@if (!calificaciones.Any())
{
    <div class="bg-yellow-100 text-yellow-800 rounded px-4 py-2 mt-4 shadow-inner">
        No hay calificaciones para este estudiante.
    </div>
}
else
{
    <div class="flex flex-col items-center my-6">
        <canvas id="promediosPieChart" style="width:300px; height:300px; max-width:300px; max-height:300px;"></canvas>
    </div>
    <table class="min-w-full text-sm text-left rounded-xl bg-gray-100 shadow-inner">
        <thead class="bg-gray-200">
            <tr>
                <th class="px-4 py-2 border-b font-semibold text-gray-600">Curso</th>
                <th class="px-4 py-2 border-b font-semibold text-gray-600">Nota</th>
                <th class="px-4 py-2 border-b font-semibold text-gray-600">Fecha</th>
                <th class="px-4 py-2 border-b font-semibold text-gray-600">Observación</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in calificaciones)
            {
                var literal = NotaLiteral(c.Puntaje);
                var color = literal switch
                {
                    "AD" => "bg-green-200 text-green-800 font-bold",
                    "A" => "bg-green-100 text-green-700 font-semibold",
                    "B" => "bg-yellow-100 text-yellow-700 font-semibold",
                    "C" => "bg-red-200 text-red-800 font-bold",
                    _ => ""
                };
                <tr>
                    <td class="px-4 py-2 border-b">@c.Estudiante_Curso?.Curso?.Nombre</td>
                    <td class="px-4 py-2 border-b">
                        <span class="px-2 py-1 rounded @color">@literal</span>
                    </td>
                    <td class="px-4 py-2 border-b">@c.FechaCalificacion.ToString("dd/MM/yyyy")</td>
                    <td class="px-4 py-2 border-b">@c.Comentario</td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = [
            @foreach (var item in promediosPorCurso)
            {
                @: "@item.Curso",
            }
        ];
        const data = [
            @foreach (var item in promediosPorCurso)
            {
                @: @item.Promedio,
            }
        ];
        const dataLiteral = [
            @foreach (var item in promediosPorCurso)
            {
                @: "@PromedioLiteral((double)item.Promedio)",
            }
        ];
        const backgroundColors = [
            @foreach (var item in promediosPorCurso)
            {
                @: "@ColorNota(PromedioLiteral((double)item.Promedio))",
            }
        ];

        const ctx = document.getElementById('promediosPieChart').getContext('2d');
        new Chart(ctx, {
            type: 'pie',
            data: {
                labels: labels.map((l, i) => l + " (" + dataLiteral[i] + ")"),
                datasets: [{
                    data: data,
                    backgroundColor: backgroundColors
                }]
            },
            options: {
                responsive: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    </script>
}
