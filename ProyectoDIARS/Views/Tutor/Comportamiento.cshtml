@{
    ViewData["Title"] = "Conducta";
    var estudiante = ViewBag.Estudiante as ProyectoDIARS.Models.Estudiante;
    var conductas = ViewBag.Conductas as List<ProyectoDIARS.Models.Comportamiento> ?? new
    List<ProyectoDIARS.Models.Comportamiento>();

    // Contar las calificaciones por tipo
    var totalAD = conductas.Count(c => c.Calificacion == "AD");
    var totalA = conductas.Count(c => c.Calificacion == "A");
    var totalB = conductas.Count(c => c.Calificacion == "B");
    var totalC = conductas.Count(c => c.Calificacion == "C");
}

<h2 class="text-xl font-bold mb-4 text-blue-700">Conductas de @estudiante?.user?.UserName</h2>

@if (!conductas.Any())
{
    <div class="bg-yellow-100 text-yellow-800 rounded px-4 py-2 mt-4 shadow-inner">
        No hay registros de conducta para este estudiante.
    </div>
}
else
{
    <div class="flex flex-col md:flex-row gap-8">
        <div class="w-full md:w-1/2 flex justify-center items-center">
            <canvas id="conductaPieChart" style="width:300px; height:300px; max-width:300px; max-height:300px;"></canvas>
        </div>
        <div class="w-full md:w-1/2">
            <table class="min-w-full text-sm text-left rounded-xl bg-gray-100 shadow-inner">
                <thead class="bg-gray-200">
                    <tr>
                        <th class="px-4 py-2 border-b font-semibold text-gray-600">Fecha</th>
                        <th class="px-4 py-2 border-b font-semibold text-gray-600">Calificación</th>
                        <th class="px-4 py-2 border-b font-semibold text-gray-600">Descripción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in conductas)
                    {
                        <tr>
                            <td class="px-4 py-2 border-b">@c.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-2 border-b">@c.Calificacion</td>
                            <td class="px-4 py-2 border-b">@c.Descripcion</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('conductaPieChart').getContext('2d');
        const data = {
            labels: ['AD', 'A', 'B', 'C'],
            datasets: [{
                data: [@totalAD, @totalA, @totalB, @totalC],
                backgroundColor: [
                    '#22c55e', // verde para AD
                    '#4ade80', // verde claro para A
                    '#fde047', // amarillo para B
                    '#f87171'  // rojo para C
                ]
            }]
        };
        const config = {
            type: 'pie',
            data: data,
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        };
        new Chart(ctx, config);
    </script>
}

