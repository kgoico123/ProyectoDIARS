@{
    ViewBag.Title = "Página de Inicio del Padre";
    var estudiantes = ViewBag.Estudiantes as List<ProyectoDIARS.Models.Estudiante> ?? new
    List<ProyectoDIARS.Models.Estudiante>();
}

<link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.4.1/dist/tailwind.min.css" rel="stylesheet">

<div class="max-w-2xl mx-auto mt-8 bg-gray-100 rounded-2xl shadow p-8">
    <h2 class="text-2xl font-bold mb-4 text-blue-700">Mis hijos/as</h2>
    @if (!estudiantes.Any())
    {
        <div class="bg-yellow-100 text-yellow-800 rounded px-4 py-2 mt-4 shadow-inner">
            No tiene estudiantes asignados.
        </div>
    }
    else
    {
        <table class="min-w-full text-sm text-left rounded-xl bg-gray-100 shadow-inner">
            <thead class="bg-gray-200">
                <tr>
                    <th class="px-4 py-2 border-b font-semibold text-gray-600">Nombre</th>
                    <th class="px-4 py-2 border-b font-semibold text-gray-600">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var est in estudiantes)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-4 py-2 border-b">@est.user?.UserName</td>
                        <td class="px-4 py-2 border-b">
                            <a href="@Url.Action("Notificaciones", "Tutor", new { estudianteId = est.IdEstudiante })"
                                class="text-blue-600 hover:underline mr-2">Ver Notificaciones</a>
                            <a href="@Url.Action("Comportamiento", "Tutor", new { estudianteId = est.IdEstudiante })"
                                class="text-green-600 hover:underline">Ver Conducta</a>
                            <a href="@Url.Action("Calificaciones", "Tutor", new { estudianteId = est.IdEstudiante })"
                                class="text-purple-600 hover:underline ml-2">Ver Calificaciones</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
